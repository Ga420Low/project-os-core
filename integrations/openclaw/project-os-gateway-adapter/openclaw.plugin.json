{
  "id": "project-os-gateway-adapter",
  "name": "Project OS Gateway Adapter",
  "description": "Fait transiter les evenements operateur OpenClaw vers le Gateway canonique de Project OS.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectOsRepoRoot": {
        "type": "string",
        "default": "D:/ProjectOS/project-os-core"
      },
      "projectOsConfigPath": {
        "type": "string",
        "default": "D:/ProjectOS/project-os-core/config/storage_roots.local.json"
      },
      "projectOsPolicyPath": {
        "type": "string",
        "default": "D:/ProjectOS/project-os-core/config/runtime_policy.local.json"
      },
      "pythonCommand": {
        "type": "string",
        "default": "py"
      },
      "defaultTargetProfile": {
        "type": "string",
        "default": "core"
      },
      "defaultRequestedWorker": {
        "type": "string"
      },
      "defaultRiskClass": {
        "type": "string",
        "enum": ["read_only", "safe_write", "destructive"]
      },
      "enabledChannels": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["discord", "webchat"]
        },
        "default": ["discord", "webchat"]
      },
      "discordAccountId": {
        "type": "string",
        "description": "Identifiant du compte Discord configure dans OpenClaw pour la boucle sortante."
      },
      "operatorTargets": {
        "type": "object",
        "description": "Map des channel hints Project OS vers les cibles Discord OpenClaw.",
        "additionalProperties": {
          "type": "string"
        },
        "default": {}
      },
      "operatorPollingIntervalMs": {
        "type": "integer",
        "minimum": 5000,
        "maximum": 300000,
        "default": 60000
      },
      "enablePolling": {
        "type": "boolean",
        "default": true
      },
      "suppressNativeDiscordReplies": {
        "type": "boolean",
        "default": true,
        "description": "Bloque les reponses natives d'OpenClaw sur Discord afin que Project OS reste l'unique voix operateur."
      },
      "sendAckReplies": {
        "type": "boolean",
        "default": false
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000,
        "default": 45000
      }
    }
  }
}
