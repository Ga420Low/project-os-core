{
  "agents": {
    "defaults": {
      "workspace": "/srv/project-os/data/openclaw/main/workspace"
    }
  },
  "tools": {
    "profile": "coding"
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "allowTailscale": true
    },
    "tailscale": {
      "mode": "off"
    }
  },
  "logging": {
    "redactSensitive": "tools"
  }
}
